# ===================================================================
# .env.example - Plantilla de Entorno Local para el BFF / API Gateway
# IMPORTANTE: Copia este archivo como '.env' y completa los valores.
# ===================================================================

# === SERVER CONFIGURATION ===
SERVER_PORT=8082

# === MICROSERVICES INTERNAL URLS ===
URL_MASCOTAS=http://sanos_ms_mascotas:8080
URL_GEOLOCALIZACION=http://sanos_ms_geolocalizacion:8081

# === SECURITY CONFIGURATION (Clerk) ===
# Encuentra tu Issuer URI en el Dashboard de Clerk (suele terminar en .clerk.accounts.dev/)
CLERK_ISSUER_URI=https://tu-issuer-de-clerk.clerk.accounts.dev/